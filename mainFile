import org.junit.jupiter.api.Test;
import java.util.*;
import static org.junit.jupiter.api.Assertions.*;

class NumberRangeSummarizerImplTest {

    private final NumberRangeSummarizer summarizer = new NumberRangeSummarizerImpl();

    @Test
    void collect_nullInput_returnsEmpty() {
        assertTrue(summarizer.collect(null).isEmpty());
    }

    @Test
    void collect_emptyString_returnsEmpty() {
        assertTrue(summarizer.collect("").isEmpty());
    }

    @Test
    void collect_singleNumber_returnsListWithThatNumber() {
        Collection<Integer> result = summarizer.collect("42");
        assertEquals(List.of(42), new ArrayList<>(result));
    }

    @Test
    void collect_numbersWithSpaces_parsedCorrectly() {
        Collection<Integer> result = summarizer.collect("1, 3, 6, 7, 8");
        assertEquals(List.of(1, 3, 6, 7, 8), new ArrayList<>(result));
    }

    @Test
    void collect_invalidTokens_ignored() {
        Collection<Integer> result = summarizer.collect("1, two, 3, 4.5, 5");
        assertEquals(List.of(1, 3, 5), new ArrayList<>(result));
    }

    @Test
    void collect_unsortedWithDuplicates_returnsSortedUnique() {
        Collection<Integer> result = summarizer.collect("5,3,1,3,2");
        assertEquals(List.of(1, 2, 3, 5), new ArrayList<>(result));
    }

    @Test
    void summarizeCollection_nullInput_throwsException() {
        assertThrows(IllegalArgumentException.class, () -> summarizer.summarizeCollection(null));
    }

    @Test
    void summarizeCollection_emptyCollection_returnsEmptyString() {
        assertEquals("", summarizer.summarizeCollection(Collections.emptyList()));
    }

    @Test
    void summarizeCollection_singleNumber_returnsThatNumber() {
        assertEquals("5", summarizer.summarizeCollection(List.of(5)));
    }

    @Test
    void summarizeCollection_twoSeparateNumbers_returnsCommaSeparated() {
        assertEquals("1, 3", summarizer.summarizeCollection(List.of(1, 3)));
    }

    @Test
    void summarizeCollection_sequentialNumbers_returnsRange() {
        assertEquals("6-8", summarizer.summarizeCollection(List.of(6, 7, 8)));
    }

    @Test
    void summarizeCollection_sampleInput_returnsExpectedString() {
        Collection<Integer> input = summarizer.collect("1,3,6,7,8,12,13,14,15,21,22,23,24,31");
        String result = summarizer.summarizeCollection(input);
        assertEquals("1, 3, 6-8, 12-15, 21-24, 31", result);
    }

    @Test
    void summarizeCollection_unsortedInput_worksCorrectly() {
        Collection<Integer> input = new HashSet<>(List.of(8, 6, 7, 12, 13));
        assertEquals("6-8, 12-13", summarizer.summarizeCollection(input));
    }

    @Test
    void summarizeCollection_mixedGapsAndRanges_worksCorrectly() {
        Collection<Integer> input = List.of(1, 2, 5, 10, 11, 12, 20);
        assertEquals("1-2, 5, 10-12, 20", summarizer.summarizeCollection(input));
    }
}
